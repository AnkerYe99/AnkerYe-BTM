[Unit]
Description=NginxFlow API Server
After=network.target nginx.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/nginxflow
ExecStart=/opt/nginxflow/nginxflow-server -config /opt/nginxflow/config.yaml
Restart=on-failure
RestartSec=5
Environment=TZ=Asia/Shanghai

[Install]
WantedBy=multi-user.target
